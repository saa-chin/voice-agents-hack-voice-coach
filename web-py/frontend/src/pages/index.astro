---
import '../styles/global.css';
import CoachApp from '../components/CoachApp';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#09090b" />
    <title>Voice Coach — on-device speech practice</title>
    <meta
      name="description"
      content="Drill-driven speech coaching powered by Gemma 4 + Cactus, running entirely on your machine."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!--
      client:only="react" instead of client:load: the entire app is interactive
      with no static content worth SSR-ing, and several state checks (window,
      speechSynthesis, MediaRecorder) differ between server and client and
      would cause hydration mismatches that destabilise the speech engine.
    -->
    <CoachApp client:only="react">
      <div slot="fallback" class="mx-auto max-w-2xl px-6 py-10 text-zinc-500">
        Loading interface…
      </div>
    </CoachApp>
  </body>
</html>
