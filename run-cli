#!/usr/bin/env bash
# run-cli — launch the on-device Cactus chat REPL (text or continuous voice).
#
# Usage:
#   ./run-cli                          # interactive: choose text or voice
#   ./run-cli --text                   # text chat (Gemma 4)
#   ./run-cli --voice                  # continuous voice chat — Gemma 4
#                                      # listens to your audio NATIVELY
#                                      # (no Whisper); replies via macOS `say`
#   ./run-cli --model <hf/id>          # override chat model
#   ./run-cli --voice-name Samantha    # macOS `say` voice
#   ./run-cli --system "..."           # override system prompt
#   ./run-cli --list-models            # list locally downloaded weights
#   ./run-cli -- --temperature 0.2     # pass extra args straight to chat.py
#   ./run-cli -h | --help              # this help
#
# Does everything end-to-end: tool checks, model download, Python deps for
# voice mode, then execs cli/chat.py via python3.14.

set -u
set -o pipefail

if [[ -t 1 ]]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RED=$'\033[31m'; GRN=$'\033[32m'
  YLW=$'\033[33m'; BLU=$'\033[34m'; RST=$'\033[0m'
else
  BOLD=""; DIM=""; RED=""; GRN=""; YLW=""; BLU=""; RST=""
fi

step() { printf "\n${BOLD}${BLU}==>${RST} ${BOLD}%s${RST}\n" "$*"; }
info() { printf "    ${DIM}%s${RST}\n" "$*"; }
ok()   { printf "    ${GRN}✓${RST} %s\n" "$*"; }
warn() { printf "    ${YLW}!${RST} %s\n" "$*"; }
die() {
  printf "\n${BOLD}${RED}✗ %s${RST}\n" "$1" >&2
  shift || true
  for line in "$@"; do
    printf "  ${DIM}→${RST} %s\n" "$line" >&2
  done
  printf "\n"
  exit 1
}

show_help() { sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'; exit 0; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_DIR="$SCRIPT_DIR/cli"
CHAT_PY="$CLI_DIR/chat.py"
WEIGHTS_DIR="/opt/homebrew/opt/cactus/libexec/weights"

[[ -f "$CHAT_PY" ]] || die "Could not find $CHAT_PY" \
  "Run this script from the repo root."

LIST_MODELS=0
MODE=""
MODEL="google/gemma-4-e2b-it"
PASSTHRU=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)        show_help ;;
    --list-models)    LIST_MODELS=1; shift ;;
    --text)           MODE="text"; shift ;;
    --voice)          MODE="voice"; shift ;;
    --mode)
      [[ $# -ge 2 ]] || die "--mode requires text or voice"
      MODE="$2"; shift 2 ;;
    --mode=*)         MODE="${1#*=}"; shift ;;
    --model)
      [[ $# -ge 2 ]] || die "--model requires a value"
      MODEL="$2"; shift 2 ;;
    --model=*)        MODEL="${1#*=}"; shift ;;
    --)               shift; PASSTHRU+=( "$@" ); break ;;
    *)                PASSTHRU+=( "$1" ); shift ;;
  esac
done

step "Checking required tools"

require_cmd() {
  local cmd="$1"; shift
  if ! command -v "$cmd" >/dev/null 2>&1; then
    die "Missing required tool: '$cmd'" "$@"
  fi
  ok "$cmd → $(command -v "$cmd")"
}

require_cmd python3.14 \
  "Install with: brew install python@3.14" \
  "(Cactus Python bindings ship for 3.14.)"
require_cmd cactus \
  "Install with: brew install cactus-compute/cactus/cactus"

CACTUS_PY="/opt/homebrew/lib/python3.14/site-packages/cactus.py"
[[ -f "$CACTUS_PY" ]] || die "Cactus Python bindings missing." \
  "Expected at: $CACTUS_PY" \
  "Reinstall: brew reinstall cactus-compute/cactus/cactus"
ok "cactus.py → $CACTUS_PY"

CACTUS_DYLIB="/opt/homebrew/opt/cactus/lib/libcactus.dylib"
[[ -f "$CACTUS_DYLIB" ]] || die "libcactus.dylib missing." \
  "Expected at: $CACTUS_DYLIB" \
  "Reinstall: brew reinstall cactus-compute/cactus/cactus"
ok "libcactus.dylib → $CACTUS_DYLIB"

# Symlink dylib so cactus.py can find it
EXPECTED_LIB="/opt/homebrew/lib/cactus/build/libcactus.dylib"
if [[ ! -e "$EXPECTED_LIB" ]]; then
  mkdir -p "$(dirname "$EXPECTED_LIB")"
  ln -sf "$CACTUS_DYLIB" "$EXPECTED_LIB"
  ok "Symlinked $EXPECTED_LIB → $CACTUS_DYLIB"
fi

step "Available local models"
if [[ -d "$WEIGHTS_DIR" ]]; then
  LOCAL_MODELS="$(ls -1 "$WEIGHTS_DIR" 2>/dev/null || true)"
  if [[ -n "$LOCAL_MODELS" ]]; then
    printf '%s\n' "$LOCAL_MODELS" | sed 's/^/      • /'
  else
    warn "No models downloaded yet."
  fi
else
  warn "Weights dir not found: $WEIGHTS_DIR"
fi

if [[ "$LIST_MODELS" -eq 1 ]]; then
  exit 0
fi

# --- pick mode interactively if not given ----------------------------------
if [[ -z "$MODE" ]]; then
  if [[ -t 0 ]]; then
    step "Pick a mode"
    info "  1) text chat"
    info "  2) voice chat (continuous, mic + TTS)"
    while true; do
      printf "    choice [1/2]: "
      read -r choice || { MODE="text"; break; }
      case "$choice" in
        1|t|text)  MODE="text"; break ;;
        2|v|voice) MODE="voice"; break ;;
        *) info "enter 1 or 2" ;;
      esac
    done
  else
    MODE="text"
  fi
fi
[[ "$MODE" == "text" || "$MODE" == "voice" ]] \
  || die "Invalid mode: '$MODE' (expected text or voice)"
ok "Mode: $MODE"

# --- ensure chat model downloaded ------------------------------------------
ensure_model() {
  local mid="$1"
  local label="$2"
  local dirname
  dirname="$(basename "$mid")"
  if [[ -d "$WEIGHTS_DIR/$dirname" ]] && [[ -n "$(ls -A "$WEIGHTS_DIR/$dirname" 2>/dev/null || true)" ]]; then
    ok "$label model present: $dirname"
    return 0
  fi
  step "Downloading $label model: $mid"
  info "First-time download — may take a while."
  if ! cactus download "$mid"; then
    die "cactus download $mid failed." \
        "Check internet, disk space, or HF auth (if gated)."
  fi
  ok "Downloaded: $dirname"
}

ensure_model "$MODEL" "chat"

if [[ "$MODE" == "voice" ]]; then
  step "Ensuring Python deps for voice (sounddevice, numpy, cffi)"
  if python3.14 -c "import sounddevice, numpy, _cffi_backend" >/dev/null 2>&1; then
    ok "sounddevice + numpy + cffi backend already installed"
  else
    info "Installing into python3.14 site-packages…"
    python3.14 -m pip install --quiet --break-system-packages sounddevice numpy >/dev/null 2>&1 || true

    # cffi via brew may ship without a usable C extension on python 3.14.
    # If _cffi_backend is missing, force a source build.
    if ! python3.14 -c "import _cffi_backend" >/dev/null 2>&1; then
      info "Rebuilding cffi from source (brew shim missing _cffi_backend)…"
      SITE="/opt/homebrew/lib/python3.14/site-packages"
      rm -rf "$SITE/cffi" "$SITE/cffi-"*.dist-info "$SITE/pycparser" "$SITE/pycparser-"*.dist-info 2>/dev/null || true
      python3.14 -m pip install --quiet --break-system-packages --no-binary cffi cffi >/dev/null 2>&1 \
        || die "Failed to build cffi from source." \
               "Try manually: python3.14 -m pip install --break-system-packages --no-binary cffi cffi"
    fi

    if ! python3.14 -c "import sounddevice, numpy, _cffi_backend" >/dev/null 2>&1; then
      die "Voice deps still not importable after install." \
          "Manual fix:" \
          "  python3.14 -m pip install --break-system-packages sounddevice numpy" \
          "  python3.14 -m pip install --break-system-packages --no-binary cffi cffi" \
          "If sounddevice fails: brew install portaudio"
    fi
    ok "Installed sounddevice + numpy + cffi"
  fi

  if ! command -v say >/dev/null 2>&1; then
    warn "macOS 'say' not found — TTS will be silent."
  fi
fi

# --- launch ---------------------------------------------------------------
step "Launching $MODE chat"
if [[ "$MODE" == "voice" ]]; then
  info "Speak naturally. ~900ms pause to send. Ctrl+C exits."
else
  info "Commands inside REPL: /reset, /quit"
fi

ARGS=( "--mode" "$MODE" "--model" "$MODEL" )
ARGS+=( ${PASSTHRU[@]+"${PASSTHRU[@]}"} )

exec python3.14 "$CHAT_PY" "${ARGS[@]}"
